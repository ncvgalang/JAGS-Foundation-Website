---
import BaseLayout from '../layouts/BaseLayout.astro';
const pageTitle = "Contact Us";
---

<BaseLayout pageTitle={pageTitle}>
	<section class="contact-section">
		<p>If you have questions about the scholarship, please send us a message below.</p>

		<form class="contact-form" name="contact" method="POST" data-netlify="true">
			<!-- Required hidden input -->
			<input type="hidden" name="contact-us" value="contact" />

			<div class="form-field">
				<label for="name">Name</label>
				<input type="text" id="name" name="name" required />
			</div>

			<div class="form-field">
				<label for="email">Email</label>
				<input type="email" id="email" name="email" required />
			</div>

			<div class="form-field">
				<label for="message">Message</label>
				<textarea id="message" name="message" required></textarea>
			</div>

			<button class="submit-button" type="submit">Send Message</button>
		</form>
	</section>

	<p>
		For questions related to financial aid, you may also contact the
		<a href="https://bulsu.edu.ph/students/scholarship">BULSU
		Scholarship and Financial Assistance Office</a> directly at ?.
	</p>
</BaseLayout>